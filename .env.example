# Copy this file to .env.local.
# Leave the project ID blank to run on the built-in demo content (great for
# screenshots). When you're ready to connect a client's CMS, paste their
# Sanity project ID below — create one free at https://sanity.io/manage
# Note: a project ID may only contain a-z, 0-9 and dashes.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
